# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # Disable code signing for all Pod targets on CI — they don't need
    # provisioning profiles and will error if one is manually specified.
    target.build_configurations.each do |config|
      config.build_settings['CODE_SIGNING_ALLOWED']      = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED']     = 'NO'
      config.build_settings['CODE_SIGN_IDENTITY']        = ''
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ''
    end
  end

  # ── connectivity_plus patch ─────────────────────────────────────────────────
  # connectivity_plus 7.1.1 references NWPath.isUltraConstrained which is an
  # iOS 26.0 API. GitHub Actions CI runs Xcode 16.x (iOS 18 SDK) which does
  # not include this API, causing a Swift compile error even with #available.
  # We remove the entire block — satellite detection is non-critical.
  connectivity_file = Dir[File.join(
    ENV['HOME'], '.pub-cache', 'hosted', 'pub.dev',
    'connectivity_plus-*', 'ios', 'connectivity_plus', 'Sources',
    'connectivity_plus', 'PathMonitorConnectivityProvider.swift'
  )].first
  if connectivity_file && File.exist?(connectivity_file)
    content = File.read(connectivity_file)
    if content.include?('isUltraConstrained')
      # Remove the entire #available block that uses isUltraConstrained
      patched = content.gsub(
        /\s*if #available\([^)]*\),\s*path\.isUltraConstrained \{[^}]*\}/m,
        ''
      )
      File.write(connectivity_file, patched)
      puts 'Patched connectivity_plus: removed isUltraConstrained block (iOS 26 API not in CI SDK)'
    end
  end

  # ── device_info_plus patch ───────────────────────────────────────────────────
  # device_info_plus 12.4.0 calls [NSProcessInfo isiOSAppOnVision] which is an
  # iOS 26.1 API. Xcode 16 CI (iOS 18 SDK) doesn't declare this selector at all,
  # causing a compile error despite the @available(iOS 26.1, *) guard.
  # We replace the conditional block so isiOSAppOnVision always returns NO,
  # which is the correct value for any non-Vision-Pro device anyway.
  device_info_file = Dir[File.join(
    ENV['HOME'], '.pub-cache', 'hosted', 'pub.dev',
    'device_info_plus-*', 'ios', 'device_info_plus', 'Sources',
    'device_info_plus', 'FPPDeviceInfoPlusPlugin.m'
  )].first
  if device_info_file && File.exist?(device_info_file)
    content = File.read(device_info_file)
    if content.include?('isiOSAppOnVision')
      patched = content.gsub(
        /NSNumber \*isiOSAppOnVision = \[NSNumber numberWithBool:NO\];\s*if \(@available\([^)]*\)\) \{\s*isiOSAppOnVision = \[NSNumber numberWithBool:\[info isiOSAppOnVision\]\];\s*\}/m,
        'NSNumber *isiOSAppOnVision = [NSNumber numberWithBool:NO]; /* iOS 26.1+ only — patched for Xcode 16 CI */'
      )
      File.write(device_info_file, patched)
      puts 'Patched device_info_plus: stubbed isiOSAppOnVision to NO (iOS 26.1 API not in CI SDK)'
    end
  end
end
