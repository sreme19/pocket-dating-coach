{
	"name": "pocket-dating-coach",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:mobile": "MOBILE_BUILD=true VITE_MOBILE=true PUBLIC_API_BASE_URL=https://pocket-dating-coach.vercel.app vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.check.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest --run",
		"test:watch": "vitest",
		"ingest": "npx tsx --env-file=.env.local scripts/ingest.ts",
		"seed:profiles": "tsx --env-file=.env.local scripts/seed-profiles.ts",
		"seed:preferences": "tsx --env-file=.env.local scripts/seed-preferences.ts",
		"verify:preferences": "tsx --env-file=.env.local scripts/verify-preferences-migration.ts",
		"setup:fal": "node scripts/setup-fal-key.js",
		"configure:rls": "tsx --env-file=.env.local scripts/configure-rls.ts",
		"apply:rls": "tsx --env-file=.env.local scripts/apply-rls-policies.ts",
		"verify:prod-env": "tsx --env-file=.env.production scripts/verify-production-env.ts",
		"verify:local-env": "tsx --env-file=.env.local scripts/verify-production-env.ts",
		"generate:bios": "tsx --env-file=.env.local scripts/generate-about-bios.ts",
		"cap:sync": "cap sync",
		"cap:open": "cap open android",
		"cap:build": "npm run build:mobile && cap sync",
		"cap:open:ios": "cap open ios",
		"cap:sync:ios": "cap sync ios",
		"cap:build:ios": "npm run build:mobile && cap sync ios"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest-axe": "^3.5.9",
		"@types/node": "^25.6.0",
		"@vitest/ui": "^3.2.4",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"fast-check": "^4.8.0",
		"jest-axe": "^10.0.0",
		"jsdom": "^29.1.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^6.3.0",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.92.0",
		"@capacitor/android": "^8.3.4",
		"@capacitor/cli": "^8.3.4",
		"@capacitor/core": "^8.3.4",
		"@capacitor/ios": "^8.4.0",
		"@capacitor/push-notifications": "^8.1.1",
		"@fal-ai/client": "^1.10.1",
		"@supabase/supabase-js": "^2.105.1",
		"@vercel/functions": "^3.6.1",
		"chart.js": "^4.5.1",
		"livekit-client": "^2.19.1",
		"livekit-server-sdk": "^2.15.4",
		"lucide-svelte": "^1.0.1",
		"pdf-parse": "^1.1.1",
		"voyageai": "^0.2.1"
	}
}
