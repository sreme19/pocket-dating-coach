# Environment Variables Template
# 
# Copy this file to .env.local for local development
# Copy this file to .env.production for production deployment
# DO NOT commit .env.local or .env.production to git
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in all required values from your services
# 3. For production, also create .env.production with production values
# 4. Verify setup: npm run verify:prod-env

# ============================================================================
# ANTHROPIC API - Claude AI Integration
# ============================================================================
# Get from: https://console.anthropic.com/account/keys
# Used for: AI Bestie and AI Wingman response generation
# Required: YES
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================================
# SUPABASE - Database and Backend Services
# ============================================================================
# Get these from your Supabase project settings > API
# https://app.supabase.com/project/[project-id]/settings/api
# Required: YES for all

# Public URL for client-side Supabase initialization
# Format: https://your-project.supabase.co
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key for client-side operations
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-side URL for backend operations
# Format: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Service role key for server-side operations (KEEP SECRET)
# Used for: AI assistant conversations, profile management, RLS-protected operations
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================================================
# VOYAGE AI - Vector Embeddings for Semantic Search
# ============================================================================
# Get from: https://dash.voyageai.com/api-keys
# Used for: Semantic search and embeddings for match context
# Required: NO (optional, but recommended for better search)
# Format: pa-...
VOYAGE_API_KEY=pa-...

# ============================================================================
# FIREBASE CLOUD MESSAGING - Push Notifications (FCM V1 API)
# ============================================================================
# Get from: Firebase Console > Project Settings > Service accounts >
#           "Generate new private key" → download JSON → paste entire content here (minified)
# Used for: Sending push notifications via FCM HTTP V1 API (OAuth2)
# Required: YES (for push notification delivery)
# Format: {"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"...@...gserviceaccount.com",...}
FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ============================================================================
# OPTIONAL: Development and Testing
# ============================================================================
# Skip SvelteKit verification during development (optional)
# Set to true for faster development builds
# VITE_SKIP_VERIFICATION=true

# Seed account password for testing (optional)
# Used for creating test accounts during development
SEED_ACCOUNT_PASSWORD=SeedPass123!

# ============================================================================
# OPTIONAL: Plane Integration (Project Management)
# ============================================================================
# Get from: https://app.plane.so/settings/api-tokens
# Used for: Creating and managing project tickets
# PLANE_API_KEY=plane_api_...
# PLANE_WORKSPACE=your-workspace
# PLANE_PROJECT_ID=your-project-id

# ============================================================================
# MATCHMAKER - Multi-Agent System (AI Wingman / Bestie / Matchmaker)
# ============================================================================
# Generate with: openssl rand -hex 32
# Used for: Authenticating the Supabase Edge Function cron that triggers the
#           nightly matchmaker batch. Must match the value set in the Edge Function env.
# Required: YES (for matchmaker nightly batch)
MATCHMAKER_RUN_SECRET=your-matchmaker-run-secret-here

# ============================================================================
# OPTIONAL: FAL AI Integration (Image Generation)
# ============================================================================
# Get from: https://fal.ai/dashboard/keys
# Used for: Image generation and processing
# FAL_KEY=your-fal-key-here

# ============================================================================
# VERIFICATION
# ============================================================================
# After setting up environment variables, run:
#   npm run verify:prod-env
#
# This will verify:
# - All required variables are set
# - Supabase connectivity
# - Claude API connectivity
# - Database tables exist
#
# For more information, see: DEPLOYMENT.md

# ============================================================================
# QA CONSOLE - Admin/intern access to the AI QA review console (/admin)
# ============================================================================
# Single shared password gating the whole /admin tree (QA console + analytics).
# Give this to whoever does manual QA. Changing it logs everyone out.
# Required: YES for /admin to be reachable (fail-closed if unset).
# Generate with: openssl rand -base64 18
QA_ADMIN_PASSWORD=change-me-to-a-strong-password

# ============================================================================
# VOICE AI - AI Bestie live voice calls (feature branch: voiceAI)
# ============================================================================
# The live call runs on an off-Vercel LiveKit agent worker (see voice-agent/).
# These vars are for the Vercel APP side (token minting, voice clone, summary).

# LiveKit project (https://cloud.livekit.io). Same project as the worker.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Agent name used for explicit dispatch — must match the worker's LIVEKIT_AGENT_NAME.
LIVEKIT_AGENT_NAME=bestie-voice

# Deepgram — speech-to-text (en-IN) inside the voice agent worker
# Get from: https://console.deepgram.com
DEEPGRAM_API_KEY=

# ElevenLabs (voice cloning + the default premium bestie voice).
ELEVENLABS_API_KEY=
# A stable ElevenLabs voice_id used when she hasn't cloned her own voice.
# (A voice_id is a public identifier, not a secret — safe to commit.)
# "Sarah" — an ElevenLabs default voice usable on free plans. Library voices
# (Rachel/Aria etc.) require a paid plan. Must be a voice_id that exists for the
# account tied to ELEVENLABS_API_KEY, or TTS fails with voice_id_does_not_exist.
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Shared secret gating the worker-only callbacks (context / tools / finalize).
# Must equal the worker's VOICE_WORKER_SECRET. Generate: openssl rand -base64 24
VOICE_WORKER_SECRET=
