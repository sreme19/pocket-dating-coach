# ── LiveKit (same project as the app) ───────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Must match the app's LIVEKIT_AGENT_NAME (used for explicit dispatch).
LIVEKIT_AGENT_NAME=bestie-voice

# ── The app this worker calls back into ─────────────────────────────────────
# Production: https://pocket-dating-coach.vercel.app
APP_URL=http://localhost:5173
# Shared secret gating /api/voice/calls/:id/context, /tools, /finalize.
# Must equal VOICE_WORKER_SECRET set on the Vercel app.
VOICE_WORKER_SECRET=

# ── Speech providers ────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# Brain (same model as the app's CLAUDE_MODEL).
ANTHROPIC_API_KEY=

# Hard ceiling on a single call (seconds). Phase 1 default 6 min.
MAX_CALL_SECONDS=360
